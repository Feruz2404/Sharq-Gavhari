# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Server
PORT=5000

# CORS
# Preferred (comma-separated, supports multiple origins):
#   CLIENT_URLS=http://localhost:5173,https://sharq-gavhari.vercel.app
# Legacy single-origin fallback (used only if CLIENT_URLS is not set):
#   CLIENT_URL=https://sharq-gavhari.vercel.app
# Local dev default if nothing is set: http://localhost:5173
CLIENT_URLS=http://localhost:5173,https://sharq-gavhari.vercel.app
# CLIENT_URL=https://sharq-gavhari.vercel.app

# Set to 'false' to reject *.vercel.app preview deploys. Default: allow.
ALLOW_VERCEL_PREVIEWS=true

# Uploads
MAX_UPLOAD_MB=5
