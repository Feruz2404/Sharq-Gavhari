# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Server
PORT=5000

# CORS
# Comma-separated list of allowed frontend origins.
# Local dev:
#   CLIENT_URL=http://localhost:5173
# Production (single Vercel domain):
#   CLIENT_URL=https://your-vercel-domain.vercel.app
# Production with custom domain + Vercel preview deploys:
#   CLIENT_URL=https://sharqgavhari.uz,https://www.sharqgavhari.uz,https://sharq-gavhari.vercel.app
CLIENT_URL=http://localhost:5173

# Set to 'false' to reject *.vercel.app preview deploys. Default: allow.
ALLOW_VERCEL_PREVIEWS=true

# Uploads
MAX_UPLOAD_MB=5
