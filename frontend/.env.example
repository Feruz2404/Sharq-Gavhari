# Frontend (Vite) environment variables.
# Copy this file to `.env` for local development.
# In production, set these in Vercel → Project → Settings → Environment Variables.
#
# Local development:
#   VITE_API_URL=http://localhost:5000/api
#   VITE_PUBLIC_BASE_URL=http://localhost:5173
#
# Production (Vercel):
#   VITE_API_URL=https://YOUR_BACKEND_DOMAIN/api
#   VITE_PUBLIC_BASE_URL=https://sharq-gavhari.vercel.app
#
# The /api suffix on VITE_API_URL is required.

VITE_API_URL=http://localhost:5000/api
VITE_PUBLIC_BASE_URL=http://localhost:5173
